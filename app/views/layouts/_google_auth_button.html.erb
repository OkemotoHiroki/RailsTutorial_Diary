<div class="flex flex-col gap-2 items-start">
<% if session[:access_token].present? %>
  <%= link_to "ログアウト", logout_path,data:{ turbo_method: :delete} ,class: "py-1 px-5 bg-gray-100/50 border rounded-2xl" %>
<% else %>
  <%= link_to "Googleでログイン", google_oauth_start_path ,class: "py-1 px-5 bg-gray-100/50 border rounded-2xl " %>
<% end %> 
</div>
